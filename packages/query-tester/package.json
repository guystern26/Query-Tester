{
  "name": "@splunk/query-tester",
  "version": "0.0.1",
  "license": "UNLICENSED",
  "scripts": {
    "build": "node bin/build.js build && yarn types:build",
    "eslint": "eslint src --ext \".ts,.tsx,.js,.jsx\"",
    "eslint:ci": "yarn run eslint -f junit -o test-reports/lint-results.xml",
    "eslint:fix": "eslint src --ext \".ts,.tsx,.js,.jsx\" --fix",
    "link:app": "node bin/build.js link",
    "lint": "yarn run eslint && yarn run stylelint",
    "lint:ci": "yarn run eslint:ci && yarn run stylelint",
    "start": "webpack --watch",
    "stylelint": "stylelint \"src/**/*.{ts,tsx,js,jsx}\" --config stylelint.config.js",
    "types:build": "tsc",
    "types:start": "yarn types:build --watch"
  },
  "dependencies": {
    "@splunk/react-page": "~8.1.0",
    "@splunk/splunk-utils": "~3.3.0",
    "@splunk/themes": "~1.3.0",
    "react": "~16.13.0",
    "react-dom": "~16.13.0",
    "styled-components": "~5.3.10",
    "@splunk/query-tester-app": "^0.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/eslint-parser": "^7.20.0",
    "@splunk/babel-preset": "~4.0.0",
    "@splunk/eslint-config": "~5.0.0",
    "@splunk/stylelint-config": "~5.0.0",
    "@splunk/webpack-configs": "~7.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "babel-loader": "^8.3.0",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^7.0.0",
    "eslint": "^8.50.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^9.0.0",
    "eslint-import-resolver-webpack": "^0.13.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "html-webpack-plugin": "^5.5.0",
    "mini-css-extract-plugin": "^2.7.0",
    "postcss-loader": "^7.3.0",
    "shelljs": "^0.8.5",
    "style-loader": "^3.3.0",
    "stylelint": "^15.10.0",
    "typescript": "~5.2.0",
    "webpack": "~5.88.0",
    "webpack-cli": "~5.1.0",
    "webpack-merge": "~5.9.0"
  },
  "engines": {
    "node": ">=18.12.0"
  }
}
