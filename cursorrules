## The run loop — implement exactly this

```python
def run_test(raw_payload: dict) -> Tuple[dict, int]:
    payload  = PayloadParser.parse(raw_payload)        # parse once
    spl      = self._resolve_spl(payload)              # resolve SPL once
    analysis = self._analyzer.analyze(spl)             # analyze once

    scenario_results = []

    for scenario in payload.scenarios:
        run_id   = uuid4().hex[:8]                     # unique per scenario
        strategy = self._injector.detect_strategy(spl)

        try:
            all_events = []
            for inp in scenario.inputs:
                all_events.extend(self._generator.build_events(inp))

            if payload.test_type != 'query_only' and strategy not in ('inputlookup', 'tstats'):
                self._indexer.index_events(all_events, run_id)

            if strategy == 'lookup':
                self._lookup.create_temp_lookup(run_id, all_events)

            injected_spl = self._injector.inject(spl, run_id, strategy, scenario.inputs)
            results      = self._executor.run(injected_spl)      # ONE query per scenario

            validations, passed = self._validator.validate(payload.validation, scenario, results)

            scenario_results.append(ScenarioResult(...))

        except Exception as exc:
            logger.error('Scenario "%s" failed: %s', scenario.name, exc, exc_info=True)
            scenario_results.append(ScenarioResult(passed=False, error=str(exc), ...))

        finally:
            self._cleanup(run_id, strategy)            # ALWAYS runs

    return self._build_response(payload, analysis, scenario_results), 200
```

**Critical rules:**
- One query per scenario — not one per input
- All scenario inputs indexed together under the same `run_id` before the query runs
- `finally` cleanup runs even when exception is thrown
- All validation conditions evaluated — no short-circuit on first failure

